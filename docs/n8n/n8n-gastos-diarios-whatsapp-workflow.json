      "id": "crear-borrador-django",
      "name": "Crear Borrador Django",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1960, 180]
    },
    {
      "parameters": {
        "jsCode": "const numeroOrigen = $('Procesar JSON Gastos').item.json.numero_origen;\nconst gastos = $('Procesar JSON Gastos').item.json.gastos;\nconst creados = $json.creados ?? gastos.length;\nconst total = gastos.reduce((acumulado, item) => acumulado + Number(item.monto), 0);\nconst itemsTexto = gastos\n  .map((item) => `- ${item.descripcion}: $${item.monto.toFixed(2)}`)\n  .join('\\n');\n\nreturn [{\n  json: {\n    numero_origen: numeroOrigen,\n    texto: `🧾 Detecté ${creados} gasto(s):\\n\\n${itemsTexto}\\n\\nTotal: $${total.toFixed(2)}\\n\\n¿Confirmás? Respondé SI para guardar o NO para cancelar.`\n  }\n}];"
      },
