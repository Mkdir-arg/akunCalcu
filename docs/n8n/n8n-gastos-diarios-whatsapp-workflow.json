    {
      "parameters": {
        "jsCode": "const texto = ($('Normalizar Evento').item.json.texto || '')\n  .toLowerCase()\n  .normalize('NFD')\n  .replace(/[\\u0300-\\u036f]/g, '')\n  .trim();\n\nlet accion = 'otro';\nif (['si', 's', 'ok', 'confirmo', 'confirmar', 'dale'].includes(texto)) {\n  accion = 'si';\n} else if (['no', 'n', 'cancelar', 'cancelo'].includes(texto)) {\n  accion = 'no';\n}\n\nreturn [{\n  json: {\n    numero_origen: $('Normalizar Evento').item.json.numero_origen,\n    accion: accion,\n    texto_original: texto\n  }\n}];"
      },
