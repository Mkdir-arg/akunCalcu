    {
      "parameters": {
        "jsCode": "const payload = $json.body ?? $json;\nconst data = payload.data ?? payload;\nconst key = data.key ?? {};\nconst message = data.message ?? payload.message ?? {};\nconst audioMessage = message.audioMessage ?? data.audioMessage ?? payload.audioMessage ?? null;\nconst textMessage = message.conversation ?? message.extendedTextMessage?.text ?? data.text ?? payload.text ?? payload.body ?? '';\nconst remoteJid = key.remoteJid ?? data.remoteJid ?? payload.remoteJid ?? data.sender ?? payload.sender ?? '';\nconst numeroOrigen = String(remoteJid).split('@')[0].trim();\nconst audioUrl = data.mediaUrl ?? payload.mediaUrl ?? audioMessage?.url ?? audioMessage?.mediaUrl ?? data.url ?? payload.url ?? '';\nconst audioId = key.id ?? data.messageId ?? payload.messageId ?? '';\nconst pushName = data.pushName ?? payload.pushName ?? data.senderName ?? payload.senderName ?? '';\nconst isAudio = Boolean(audioMessage || audioUrl || data.messageType === 'audio' || payload.messageType === 'audio');\n\nreturn [{\n  json: {\n    numero_origen: numeroOrigen,\n    push_name: pushName,\n    texto: textMessage,\n    audio_url: audioUrl,\n    audio_id: audioId,\n    is_audio: isAudio\n  }\n}];"
      },
