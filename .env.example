# =========================================
# AkunCalcu — variables de entorno
# =========================================
# Copiá este archivo a `.env` para desarrollo local.
# En Railway las variables se configuran desde el dashboard del servicio.

# --- Django ---
SECRET_KEY=cambiar-en-produccion
DEBUG=True
DJANGO_SETTINGS_MODULE=akuna_calc.settings
# En Railway: DJANGO_SETTINGS_MODULE=akuna_calc.settings_prod

# Lista separada por comas. Solo necesario si DEBUG=False
ALLOWED_HOSTS=
# Ej en Railway: ALLOWED_HOSTS=akunCalcu.up.railway.app,akuna.com.ar

# Lista separada por comas con esquema (https://). Necesario si DEBUG=False y hay forms POST
CSRF_TRUSTED_ORIGINS=
# Ej en Railway: CSRF_TRUSTED_ORIGINS=https://akunCalcu.up.railway.app

# --- Base de datos ---
# Opción A: una sola URL (recomendada en Railway, mapeá a ${{ MySQL.MYSQL_URL }})
DATABASE_URL=

# Opción B: variables individuales (usadas si DATABASE_URL está vacía)
DB_NAME=akuna_calc
DB_USER=akuna
DB_PASSWORD=akuna123
DB_HOST=db
DB_PORT=3306

# --- Superusuario inicial (creado por entrypoint si no existe) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Controles de arranque del contenedor.
# En producción Railway conviene dejarlos en false para que el healthcheck no
# dependa de migraciones ni de tareas administrativas.
RUN_MIGRATIONS_ON_STARTUP=true
CREATE_SUPERUSER_ON_STARTUP=true

# --- Integraciones ---
# Secret compartido entre n8n y Django para autenticar webhooks de Telegram
TELEGRAM_BOT_SECRET=cambiar-este-secret
